{
    "name": "repair-service/app",
    "description": "Система управления заявками ремонтной службы",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php database/migrations/migrate.php",
        "seed": "php database/seeds/seed.php",
        "serve": "php -S 0.0.0.0:8080 -t public/"
    }
}
